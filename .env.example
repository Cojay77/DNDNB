# D&D&B — Build Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit the actual .env file to version control.
#
# Usage (local dev):
#   flutter run --dart-define=VAPID_KEY=your_vapid_key_here
#
# Usage (CI):
#   Add VAPID_KEY as a GitHub Actions Secret under:
#   Settings → Secrets and variables → Actions → New repository secret

# Firebase Cloud Messaging Web Push VAPID Key
# Get it from: Firebase Console → Project Settings → Cloud Messaging → Web Push certificates
VAPID_KEY=your_vapid_key_here
